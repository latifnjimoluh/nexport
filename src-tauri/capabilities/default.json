{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capacités par défaut accordées à la fenêtre principale.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "**" }]
    },
    "dialog:default",
    "dialog:allow-save",
    "notification:default",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
