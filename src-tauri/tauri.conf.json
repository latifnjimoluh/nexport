{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexPort",
  "version": "0.6.0",
  "identifier": "dev.nexport.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexPort",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Visualise et libère les ports occupés",
    "longDescription": "NexPort liste les ports ouverts (TCP/UDP, IPv4/IPv6), affiche le PID et le process associé, et permet de tuer le process en un clic.",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "languages": ["French", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
